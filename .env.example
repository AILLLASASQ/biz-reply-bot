# ===== Telegram =====
BOT_TOKEN=123456:ABC-your-bot-token

# الرابط العام لتطبيقك على Render
BASE_WEBHOOK_URL=https://your-app.onrender.com

# أي نص عشوائي طويل لحماية الويبهوك
WEBHOOK_SECRET=put_a_random_secret_here

# ===== Firestore =====
# للتشغيل المحلي فقط (مسار ملف الخدمة على جهازك):
GOOGLE_APPLICATION_CREDENTIALS=serviceAccount.json

# على Render استخدم هذا بدلاً من الملف (الصق محتوى الـ JSON كاملاً في سطر واحد):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}
